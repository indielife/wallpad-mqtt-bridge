{
  "name": "Kocom Wallpad (Local Custom)",
  "version": "0.1.1",
  "slug": "kocom_wallpad",
  "description": "Kocom Wallpad Controller for Homeassistant",
  "arch": [
    "armhf",
    "armv7",
    "aarch64",
    "amd64",
    "i386"
  ],
  "url": "https://github.com/HAKorea/addons",
  "startup": "application",
  "boot": "auto",
  "uart": true,
  "map": [
    "share:rw"
  ],
  "options": {
    "MQTT Broker": {
      "server": "",
      "username": "id",
      "password": "pw"
    },
    "Wallpad": {
      "Manufacturer": "kocom",
      "type": "Serial",
      "Socket": {
        "server": "",
        "port": 8899
      },
      "Serial": {
        "port": "/dev/ttyUSB0"
      }
    },
    "Enabled Devices": {
      "light": false,
      "plug": false,
      "thermostat": false,
      "fan": false,
      "gas": false,
      "elevator": false
    },
    "Advanced": {
      "INIT_TEMP": 22,
      "SCAN_INTERVAL": 300,
      "PACKET_DELAY": 0.8,
      "DEFAULT_SPEED": "low",
      "LOGLEVEL": "info"
    },
    "KOCOM_LIGHT_SIZE": [
      {
        "name": "livingroom",
        "number": 3
      },
      {
        "name": "bedroom",
        "number": 2
      },
      {
        "name": "room1",
        "number": 2
      },
      {
        "name": "room2",
        "number": 2
      },
      {
        "name": "kitchen",
        "number": 3
      }
    ],
    "KOCOM_PLUG_SIZE": [
      {
        "name": "livingroom",
        "number": 3
      },
      {
        "name": "bedroom",
        "number": 2
      },
      {
        "name": "room1",
        "number": 2
      },
      {
        "name": "room2",
        "number": 2
      },
      {
        "name": "kitchen",
        "number": 3
      }
    ],
    "KOCOM_ROOM": [
      "livingroom",
      "bedroom",
      "room1",
      "room2",
      "kitchen"
    ],
    "KOCOM_ROOM_THERMOSTAT": [
      "livingroom",
      "bedroom",
      "room1",
      "room2"
    ],
    "Ventilator": {
      "manufacturer": "None",
      "connection_type": "Serial",
      "Serial": {
        "controller_port": "/dev/ttyUSB1",
        "ventilator_port": "/dev/ttyUSB2"
      },
      "Socket": {
        "server": "",
        "port": 8899
      },
      "default_speed": "low"
    }
  },
  "schema": {
    "MQTT Broker": {
      "server": "str",
      "username": "str",
      "password": "str"
    },
    "Wallpad": {
      "Manufacturer": "str",
      "type": "list(Serial|Socket)",
      "Socket": {
        "server": "str?",
        "port": "int?"
      },
      "Serial": {
        "port": "str?"
      }
    },
    "Enabled Devices": {
      "light": "bool",
      "plug": "bool",
      "thermostat": "bool",
      "fan": "bool",
      "gas": "bool",
      "elevator": "bool"
    },
    "Advanced": {
      "INIT_TEMP": "int(10,30)",
      "SCAN_INTERVAL": "int(100,1000)",
      "PACKET_DELAY": "float",
      "DEFAULT_SPEED": "str",
      "LOGLEVEL": "str"
    },
    "KOCOM_LIGHT_SIZE": [
      {
        "name": "str?",
        "number": "int?"
      }
    ],
    "KOCOM_PLUG_SIZE": [
      {
        "name": "str?",
        "number": "int?"
      }
    ],
    "KOCOM_ROOM": [
      "str?"
    ],
    "KOCOM_ROOM_THERMOSTAT": [
      "str?"
    ],
    "Ventilator": {
      "manufacturer": "str",
      "connection_type": "list(Serial|Socket)",
      "Serial": {
        "controller_port": "str?",
        "ventilator_port": "str?"
      },
      "Socket": {
        "server": "str?",
        "port": "int?"
      },
      "default_speed": "str"
    }
  }
}
