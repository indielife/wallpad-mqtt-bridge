{
  "mqtt_broker": {
    "host": "192.168.0.x",
    "username": "mqtt_user",
    "password": "mqtt_password"
  },
  "wallpad": {
    "enable": true,
    "manufacturer": "kocom",
    "connection_type": "Socket",
    "socket": {
      "host": "192.168.0.x",
      "port": 8899
    },
    "serial": {
      "port": "/dev/ttyUSB0"
    },
    "enabled_devices": {
      "fan": false,
      "gas": false,
      "elevator": false
    },
    "rooms": [
      {"name": "livingroom", "room_no": 0, "light_count": 3, "plug_count": 2, "thermo_no": 0},
      {"name": "bedroom",    "room_no": 1, "light_count": 2, "plug_count": 2, "thermo_no": 1},
      {"name": "room1",      "room_no": 3, "light_count": 2, "plug_count": 2, "thermo_no": 2},
      {"name": "room2",      "room_no": 2, "light_count": 2, "plug_count": 2, "thermo_no": 3},
      {"name": "kitchen",    "room_no": 4, "light_count": 3, "plug_count": 2}
    ]
  },
  "advanced": {
    "init_temp": 22,
    "scan_interval": 300,
    "packet_delay": 0.8,
    "default_speed": "low",
    "loglevel": "info"
  },
  "ventilator": {
    "enable": false,
    "manufacturer": "none",
    "connection_type": "Serial",
    "socket": {
      "host": "",
      "port": 8899
    },
    "serial": {
      "controller_port": "/dev/ttyUSB1",
      "ventilator_port": "/dev/ttyUSB2"
    },
    "default_speed": "low"
  }
}
